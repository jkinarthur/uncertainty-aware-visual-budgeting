# Byte-compiled / optimized / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Jupyter / IDE
.ipynb_checkpoints/
.vscode/
.idea/

# Experiment outputs
outputs/
runs/
results/
*.log
wandb/

# Model / data caches (never commit weights or datasets)
data/raw/
data/cache/
checkpoints/
*.ckpt
*.pt
*.safetensors
.cache/
~/.cache/

# Calibrator artifacts are small and allowed under artifacts/
!artifacts/
artifacts/*.tmp

# OS
.DS_Store
Thumbs.db

# Secrets / credentials (never commit)
*.pem
.env
*.key
aws_credentials*
